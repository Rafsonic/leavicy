# Leavicy Portal — local environment
# Copy this file to `.env.local` and fill in the values:
#   cp .env.local.example .env.local
# Get the local Supabase values from `pnpm supabase:start` / `supabase status`.

# Supabase API URL (local dev default)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321

# Publishable (anon) key — safe for the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret (service-role) key — server-only, NEVER expose to the client
SUPABASE_SECRET_KEY=

# App display name
NEXT_PUBLIC_APP_NAME=Leavicy Portal

# --- WebAuthn / Face ID "App Unlock" (server-only) ---
# Optional in local dev: the code defaults to localhost / http://localhost:3560.
# REQUIRED in production. WebAuthn binds each passkey to one domain (anti-phishing),
# so these MUST match the domain the Portal is served from, over HTTPS.
#   WEBAUTHN_RP_ID   = bare host, no scheme/port/path   e.g. portal.leavicy.com
#   WEBAUTHN_ORIGIN  = full https origin                e.g. https://portal.leavicy.com
#   WEBAUTHN_RP_NAME = name shown in the Face ID prompt e.g. Leavicy Portal
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3560
WEBAUTHN_RP_NAME=Leavicy Portal
