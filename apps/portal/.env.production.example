# Leavicy Portal — production environment (TEMPLATE)
# Copy to `.env.production` and fill in the secret values, OR set these as
# Environment Variables in the host (Vercel EU / OpenNext, scope: Production).
# Never commit the real `.env.production` (it is gitignored).

# Supabase API URL (EU project, eu-central-1 / Frankfurt per the region rule)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (anon) key — safe for the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret (service-role) key — server-only, NEVER expose to the client
SUPABASE_SECRET_KEY=

# App display name
NEXT_PUBLIC_APP_NAME=Leavicy Portal

# --- WebAuthn / Face ID "App Unlock" (server-only) ---
# Binds each passkey to this exact domain (anti-phishing). Must match the domain
# the Portal is served from, over HTTPS.
#   WEBAUTHN_RP_ID   = bare host, no scheme/port/path
#   WEBAUTHN_ORIGIN  = full https origin (must equal the browser URL exactly)
#   WEBAUTHN_RP_NAME = name shown in the Face ID prompt
WEBAUTHN_RP_ID=portal.leavicy.com
WEBAUTHN_ORIGIN=https://portal.leavicy.com
WEBAUTHN_RP_NAME=Leavicy Portal
