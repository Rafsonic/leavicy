# Leavicy Central — local environment
# Copy this file to `.env.local` and fill in the values:
#   cp .env.local.example .env.local
# Get the local Supabase values from `pnpm supabase:start` / `supabase status`.

# Supabase API URL (local dev default)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321

# Publishable (anon) key — safe for the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret (service-role) key — server-only, NEVER expose to the client
SUPABASE_SECRET_KEY=

# App display name
NEXT_PUBLIC_APP_NAME=Leavicy Central
