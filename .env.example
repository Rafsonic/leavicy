# Per-app env lives in apps/<app>/.env.local
# Values for local dev come from `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
NEXT_PUBLIC_APP_NAME="Leavicy"

# --- MCP servers (.mcp.json) — export these in your shell before starting Claude Code ---
# Supabase access token (cloud, Account → Access Tokens): https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# (shadcn, playwright need no secrets; vercel uses OAuth on first connect)

# --- Resend (also read by the running app to send invitation emails) ---
# Put RESEND_API_KEY in each apps/<app>/.env.local to enable real emails.
# Verified sender (defaults to onboarding@resend.dev if unset):
RESEND_FROM_EMAIL="Leavicy <onboarding@resend.dev>"
